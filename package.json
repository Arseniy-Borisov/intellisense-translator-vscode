{
  "name": "intellisense-translator",

  "displayName": "IntelliSense Translator",
  "description": "Translate IntelliSense hover tooltips directly inside VSCode using a local AI model.",
  "version": "1.0.2",
  "publisher": "Arseniy-Borisov",
  "engines": {
    "vscode": "^1.100.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Arseniy-Borisov/intellisense-translator-vscode.git"
  },  
  "categories": ["Other"],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:javascript",
    "onLanguage:typescript"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -w -p ./"
  },
  "devDependencies": {
    "typescript": "^5.2.2",
    "@types/node": "^20.4.2",
    "@types/vscode": "^1.100.0"
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "icon": "icon.png",
  "keywords": [
    "translation",
    "translator",
    "intellisense",
    "hover",
    "ollama",
    "ai",
    "local ai",
    "tooltip translation",
    "translate"
  ], 
  "contributes": {
    "configuration": {
      "title": "IntelliSense Translator",
      "properties": {
        "intellisenseTranslator.ollamaEndpoint": {
          "type": "string",
          "default": "http://127.0.0.1:11434/api/generate",
          "description": "Ollama endpoint"
        },
        "intellisenseTranslator.ollamaModel": {
          "type": "string",
          "default": "ali6parmak/hy-mt1.5:1.8b",
          "description": "Ollama model name"
        },
        "intellisenseTranslator.targetLanguage": {
          "type": "string",
          "default": "Russian",
          "enum": [
            "Russian",            
            "Chinese",
            "English",
            "French",
            "Portuguese",
            "Spanish",
            "Japanese",
            "Turkish",
            "Arabic",
            "Korean",
            "Thai",
            "Italian",
            "German",
            "Vietnamese",
            "Malay",
            "Indonesian",
            "Filipino",
            "Hindi",
            "Traditional Chinese",
            "Polish",
            "Czech",
            "Dutch",
            "Khmer",
            "Burmese",
            "Persian",
            "Gujarati",
            "Urdu",
            "Telugu",
            "Marathi",
            "Hebrew",
            "Bengali",
            "Tamil",
            "Ukrainian",
            "Tibetan",
            "Kazakh",
            "Mongolian",
            "Uyghur",
            "Cantonese"
          ],
          "enumItemLabels": [
            "🇷🇺 Russian",            
            "🇨🇳 Chinese",
            "🇬🇧 English",
            "🇫🇷 French",
            "🇵🇹 Portuguese",
            "🇪🇸 Spanish",
            "🇯🇵 Japanese",
            "🇹🇷 Turkish",
            "🇸🇦 Arabic",
            "🇰🇷 Korean",
            "🇹🇭 Thai",
            "🇮🇹 Italian",
            "🇩🇪 German",
            "🇻🇳 Vietnamese",
            "🇲🇾 Malay",
            "🇮🇩 Indonesian",
            "🇵🇭 Filipino",
            "🇮🇳 Hindi",
            "🇹🇼 Traditional Chinese",
            "🇵🇱 Polish",
            "🇨🇿 Czech",
            "🇳🇱 Dutch",
            "🇰🇭 Khmer",
            "🇲🇲 Burmese",
            "🇮🇷 Persian",
            "🇮🇳 Gujarati",
            "🇵🇰 Urdu",
            "🇮🇳 Telugu",
            "🇮🇳 Marathi",
            "🇮🇱 Hebrew",
            "🇧🇩 Bengali",
            "🇮🇳 Tamil",
            "🇺🇦 Ukrainian",
            "🇨🇳 Tibetan",
            "🇰🇿 Kazakh",
            "🇲🇳 Mongolian",
            "🇨🇳 Uyghur",
            "🇭🇰 Cantonese"
          ],
          "description": "Target language for translation"
        }
      }
    }
  } 
}